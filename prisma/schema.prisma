// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core business models
model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users         User[]
  listings      Listing[]
  spaces        Space[]
  socialAccounts SocialAccount[]
  socialPosts   SocialPost[]
  eventSyncs    EventSync[]
  spaceRequests SpaceRequest[]
  auditLogs     AuditLog[]
  webhookEndpoints WebhookEndpoint[]

  @@map("businesses")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  INFLUENCER
}

model User {
  id           String   @id @default(cuid())
  businessId   String
  email        String   @unique
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  roleAssignments RoleAssignment[]
  auditLogs      AuditLog[]

  @@map("users")
}

model RoleAssignment {
  id         String @id @default(cuid())
  userId     String
  businessId String
  role       Role
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@map("role_assignments")
}

// Listing models
enum ListingType {
  RESTAURANT
  RETREAT
  EVENT
  ACTIVITY
  PROPERTY
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Listing {
  id               String        @id @default(cuid())
  businessId       String
  title            String
  slug             String        @unique
  type             ListingType
  status           ListingStatus @default(DRAFT)
  description      String?
  category         String?
  locationCity     String?
  locationCountry  String?
  photos           String[]      @default([])
  currency         String?
  priceFrom        Int?          // in cents
  capacity         Int?
  details          Json?         // type-specific data
  seoMeta          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orders   Order[]
  reviews  Review[]

  @@map("listings")
}

// Order models
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Order {
  id             String        @id @default(cuid())
  orderId        String        @unique
  listingId      String
  guestName      String
  guestEmail     String
  guestPhone     String?
  date           String
  time           String?
  checkIn        String?
  checkOut       String?
  guests         Int
  totalAmount    Int           // in cents
  paymentStatus  PaymentStatus @default(PENDING)
  status         OrderStatus   @default(PENDING)
  specialRequests String?
  waivers        Json?         // array of waiver objects
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("orders")
}

// Review models
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model Review {
  id             String       @id @default(cuid())
  listingId      String
  customerId     String
  customerName   String
  customerEmail  String
  rating         Int
  title          String
  content        String
  status         ReviewStatus @default(PENDING)
  isVerified     Boolean      @default(false)
  images         String[]     @default([])
  tags           String[]     @default([])
  reply          Json?        // reply object
  moderatorNotes String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// Social media models
enum SocialProvider {
  FACEBOOK_PAGE
  INSTAGRAM_BUSINESS
  GOOGLE_BUSINESS
  EVENTBRITE
  MEETUP
}

model SocialAccount {
  id            String         @id @default(cuid())
  businessId    String
  provider      SocialProvider
  accountId     String
  accountName   String
  accessToken   String
  refreshToken  String?
  expiresAt     DateTime?
  scopes        String[]       @default([])
  isActive      Boolean        @default(true)
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, provider, accountId])
  @@map("social_accounts")
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

model SocialPost {
  id           String       @id @default(cuid())
  businessId   String
  title        String?
  caption      String
  media        Json[]       @default([])
  platforms    String[]     @default([])
  status       PostStatus   @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  externalIds  String[]     @default([])
  results      Json[]       @default([])
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("social_posts")
}

// Event sync models
enum SyncStatus {
  PENDING
  SUCCESS
  ERROR
}

model EventSync {
  id              String       @id @default(cuid())
  businessId      String
  listingId       String?
  name            String
  platforms       String[]     @default([])
  syncDirection   String       @default("export")
  status          String       @default("ACTIVE")
  lastSyncStatus  SyncStatus   @default(PENDING)
  lastSyncAt      DateTime?
  lastSyncError   String?
  syncData        Json?
  externalIds     String[]     @default([])
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("event_syncs")
}

// Space rental models
enum SpaceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Space {
  id           String      @id @default(cuid())
  businessId   String
  title        String
  slug         String      @unique
  description  String?
  photos       String[]    @default([])
  location     Json        // {address, lat, lng}
  capacity     Int
  floorAreaM2  Int?
  status       SpaceStatus @default(DRAFT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  business      Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  amenities     SpaceAmenity[]
  rules         SpaceRule[]
  pricingRules  SpacePricingRule[]
  calendars     SpaceAvailability[]
  requests      SpaceRequest[]

  @@map("spaces")
}

model SpaceAmenity {
  id       String  @id @default(cuid())
  spaceId  String
  label    String
  category String?

  // Relations
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("space_amenities")
}

model SpaceRule {
  id       String  @id @default(cuid())
  spaceId  String
  label    String
  required Boolean @default(false)

  // Relations
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("space_rules")
}

enum PricingKind {
  HOURLY
  DAILY
  PEAK
  CLEANING_FEE
  SECURITY_DEPOSIT
}

model SpacePricingRule {
  id        String      @id @default(cuid())
  spaceId   String
  kind      PricingKind
  amount    Int         // in cents
  currency  String      @default("USD")
  dow       Int[]       @default([]) // 0=Sunday, 6=Saturday
  startHour Int?
  endHour   Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("space_pricing_rules")
}

model SpaceAvailability {
  id        String   @id @default(cuid())
  spaceId   String
  start     DateTime
  end       DateTime
  isBlocked Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@map("space_availability")
}

enum SpaceReqStatus {
  PENDING
  NEEDS_PAYMENT
  PAID_HOLD
  CONFIRMED
  DECLINED
  EXPIRED
  CANCELLED
}

model SpaceRequest {
  id               String         @id @default(cuid())
  businessId       String
  spaceId          String
  organizerId      String
  organizerName    String?
  organizerEmail   String?
  title            String
  description      String?
  attendees        Int
  start            DateTime
  end              DateTime
  status           SpaceReqStatus @default(PENDING)
  quoteAmount      Int?           // in cents
  currency         String?        @default("USD")
  depositAmount    Int?           // in cents
  cleaningFee      Int?           // in cents
  pricingBreakdown Json?
  holdExpiresAt    DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  space    Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  messages SpaceMessage[]

  @@map("space_requests")
}

model SpaceMessage {
  id          String   @id @default(cuid())
  spaceReqId  String
  senderId    String
  body        String
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  // Relations
  spaceRequest SpaceRequest @relation(fields: [spaceReqId], references: [id], onDelete: Cascade)

  @@map("space_messages")
}

// Audit log models
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorType  String   // "user" | "system" | "api"
  action     String
  entityType String
  entityId   String
  businessId String
  metadata   String?  // JSON string
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actor    User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// Webhook models
model WebhookEndpoint {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  url         String
  events      String[] @default([])
  secret      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  endpointId   String
  businessId   String
  eventType    String
  status       String   // "pending" | "success" | "failed"
  durationMs   Int?
  requestBody  Json?
  responseBody Json?
  createdAt    DateTime @default(now())

  // Relations
  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}

// Idempotency models
model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String   @unique
  requestHash String
  response    String?
  status      String   @default("pending") // "pending" | "completed" | "failed"
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("idempotency_keys")
}

// OAuth state models
model ProviderAuthState {
  id         String         @id @default(cuid())
  state      String         @unique
  provider   SocialProvider
  businessId String
  userId     String?
  expiresAt  DateTime
  createdAt  DateTime       @default(now())

  @@map("provider_auth_states")
}